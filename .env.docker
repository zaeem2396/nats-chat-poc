# Docker overrides: use this as .env when running with docker compose,
# or merge these into your .env so the app uses MySQL in containers.
# Run: php artisan key:generate (or copy from your existing .env)
APP_KEY=
APP_URL=http://localhost:8090
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nats_chat
DB_USERNAME=nats_chat
DB_PASSWORD=secret
NATS_HOST=nats
NATS_PORT=4222
QUEUE_CONNECTION=nats
NATS_QUEUE_DELAYED_ENABLED=true
NATS_ANALYTICS_HOST=nats
